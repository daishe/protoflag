package protoflag

import (
	"reflect"
	"unsafe"

	"google.golang.org/protobuf/proto"
	"google.golang.org/protobuf/reflect/protoreflect"
)

func reflectValueOfProtoreflectValueInterface(v protoreflect.Value) reflect.Value {
	i := v.Interface()
	if m, ok := i.(protoreflect.Message); ok {
		return reflect.ValueOf(m.Interface())
	}
	return reflect.ValueOf(i)
}

func reflectTypeOfProtoreflectValue(v protoreflect.Value) reflect.Type {
	if !v.IsValid() {
		return nil
	}
	switch v := v.Interface().(type) {
	case protoreflect.Message:
		return reflect.TypeFor[proto.Message]()
	case protoreflect.List:
		return reflectTypeOfProtoreflectList(v)
	case protoreflect.Map:
		return reflectTypeOfProtoreflectMap(v)
	}
	return reflect.TypeOf(v.Interface())
}

type Zeroer interface {
	Zero() protoreflect.Value
}

func reflectTypeOfProtoreflectList(li protoreflect.List) reflect.Type {
	if li == nil {
		return nil
	}
	return reflect.SliceOf(reflectTypeOfProtoreflectValue(li.NewElement()))
}

func unsafeZeroerFields(val reflect.Value) map[string]Zeroer {
	typ := val.Type()
	zeroers := map[string]Zeroer{}
	for i := 0; i < typ.NumField(); i++ {
		field := val.Field(i)
		fieldUnsafe := reflect.NewAt(field.Type(), unsafe.Pointer(field.UnsafeAddr())).Elem()
		zeroer, ok := fieldUnsafe.Interface().(Zeroer)
		if !ok {
			continue
		}
		zeroers[typ.Field(i).Name] = zeroer
	}
	return zeroers
}

func reflectTypeOfProtoreflectMap(m protoreflect.Map) reflect.Type {
	if m == nil {
		return nil
	}

	val := reflect.ValueOf(m)
	if val.Type().Kind() != reflect.Pointer {
		panic("protoflag: unknown protoreflect.Map implementation")
	}

	zeroers := unsafeZeroerFields(val.Elem())
	keyZeroer := zeroers["keyConv"]
	valZeroer := zeroers["valConv"]
	if len(zeroers) != 2 || keyZeroer == nil || valZeroer == nil {
		panic("protoflag: unknown protoreflect.Map implementation")
	}

	return reflect.MapOf(
		reflectTypeOfProtoreflectValue(keyZeroer.Zero()),
		reflectTypeOfProtoreflectValue(valZeroer.Zero()),
	)
}

func cloneProtoreflectListAsSlice(li protoreflect.List) any {
	if li == nil {
		return nil
	}
	resTyp := reflectTypeOfProtoreflectList(li)
	if !li.IsValid() {
		return reflect.Zero(resTyp).Interface()
	}
	res := reflect.MakeSlice(resTyp, li.Len(), li.Len())
	for i := 0; i < li.Len(); i++ {
		res.Index(i).Set(reflectValueOfProtoreflectValueInterface(li.Get(i)))
	}
	return res.Interface()
}

func cloneProtoreflectMapAsMap(m protoreflect.Map) any {
	if m == nil {
		return nil
	}
	resTyp := reflectTypeOfProtoreflectMap(m)
	if !m.IsValid() {
		return reflect.Zero(resTyp).Interface()
	}
	res := reflect.MakeMapWithSize(resTyp, m.Len())
	for k, v := range m.Range {
		res.SetMapIndex(
			reflectValueOfProtoreflectValueInterface(k.Value()),
			reflectValueOfProtoreflectValueInterface(v),
		)
	}
	return res.Interface()
}
